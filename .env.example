# Supabase — copy this file to .env.local and fill in your project values.
# Only VITE_-prefixed vars are exposed to the browser build (that's intended:
# the anon key is safe for the client WITH Row-Level Security enabled).
# NEVER put the service_role key here — it stays server-side only.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ── Server-side only (serverless functions + email-ingest service) ──────────
# Service-role key bypasses RLS — keep it server-side, never in a VITE_ var.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Email-to-order ingest (services/email_ingest) ──────────────────────────
# Dedicated orders inbox, read over IMAP (Gmail works with an App Password).
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=orders@yourfirm.com
IMAP_PASS=YOUR-APP-PASSWORD
IMAP_FOLDER=INBOX
POLL_INTERVAL_SEC=120
CONFIDENCE_THRESHOLD=0.8

# LLM provider — "gemini" (default) or "local".
LLM_PROVIDER=gemini
# GeminiProvider (default): native PDF input + JSON mode.
GEMINI_API_KEY=YOUR-GEMINI-API-KEY
GEMINI_MODEL=gemini-2.5-flash
# LocalLLMProvider (fallback): any OpenAI-compatible endpoint (e.g. Ollama).
# PDFs are converted to text (text layer + tesseract OCR) before sending.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1
