# Supabase — copy this file to .env.local and fill in your project values.
# Only VITE_-prefixed vars are exposed to the browser build (that's intended:
# the anon key is safe for the client WITH Row-Level Security enabled).
# NEVER put the service_role key here — it stays server-side only.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
